@startuml
'https://plantuml.com/class-diagram

Etape <|-- Activite
Etape <|-- Guichet
Activite <|--"1" SasEntree
Activite <|--"1" SasSortie
Activite <|-- ActiviteRestreinte
GestionnaireEtapes "1"-right-"*" Etape

class Activite {
- int temps
- int ecartTemps
+ Activite(String nom)
+ Activite(String nom, int temps, int ecartTemps)
+ boolean estUneActivite()
+ String toString()
}

class ActiviteRestreinte {
+ ActiviteRestreinte(String nom)
+ ActiviteRestreinte(String nom, int temps, int ecartTemps)
}

abstract class Etape {
- String nom
+ Etape(String nom)
+ void ajouterSuccesseur(Etape... e)
+ int nbSuccesseur()
+ Etape getSuccesseur(int index)
+ boolean estUneActivite()
+ boolean estUnGuichet()
+ Iterator<Etape> iterator()
+ String getNom()
}

class GestionnaireEtapes {
- ArrayList<Etape> etapes
+ GestionnaireEtapes()
+ void ajouter(Etape... etapes)
+ int nbEtapes()
+ Etape getEtapes(int index)
+ Iterator<Etape> iterator()
}

class Guichet {
- int nbJetons
+ Guichet(String nom)
+ Guichet(String nom, int nbJetons)
+ boolean estUnGuichet()
+ String toString()
}

class SasEntree {
+ asEntree()
}

class SasSortie {
+ SasSortie()
}

@enduml